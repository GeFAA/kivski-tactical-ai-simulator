# Kivski Tactical AI Simulator - example environment variables.
# Copy to .env and adjust as needed.

# --- API server ---
KIVSKI_HOST=127.0.0.1
KIVSKI_PORT=8000
KIVSKI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Training ---
KIVSKI_DEFAULT_CONFIG=configs/default.yaml
KIVSKI_CHECKPOINT_DIR=models/checkpoints
KIVSKI_REPLAY_DIR=models/replays
KIVSKI_LOG_DIR=models/logs

# --- Telemetry ---
# Leave empty to disable Weights & Biases (falls back to CSV + TensorBoard).
WANDB_API_KEY=
KIVSKI_WANDB_PROJECT=kivski-tactical-ai
KIVSKI_WANDB_MODE=offline

# --- Compute ---
KIVSKI_DEVICE=auto         # auto | cpu | cuda
KIVSKI_SEED=20260523
KIVSKI_NUM_ENVS=16
